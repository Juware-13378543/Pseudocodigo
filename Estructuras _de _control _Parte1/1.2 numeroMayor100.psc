Algoritmo numeroMayor100
	
	//Definir variable
	Definir numeroUsuario Como Real;
	
	//Inicializar
	Escribir "Seþor usuario ingrese un valor Numerico";
	Leer numeroUsuario;
	
	//Condicional Simple
	Si numeroUsuario > 100 Entonces
		Escribir "El numero ingresado es menor que 100";
		Escribir "El numero ingresado Es: ",numeroUsuario;
	FinSi
	
FinAlgoritmo
