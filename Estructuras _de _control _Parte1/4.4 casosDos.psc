Algoritmo casosDos
	
	//Definir 
	Definir Mes como Cadena;
	
	//Variable A evaluiar del tipo de dato cadena
	Escribir "Ingresa un mes del ańo";
	Leer mes;
	
	Segun mes Hacer
		"diciembre","DICIEMBRE","Diciembre":
			Escribir "Feliz navidad, jojojo";
		De Otro Modo:
			Escribir "En este mes no se celebra navidad";
	FinSegun
	
FinAlgoritmo
