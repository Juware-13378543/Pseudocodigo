Algoritmo funcionesConcatenar
	
	//definir variable
	Definir saludoUno, saludoDos, fConcatenar como Cadena;
	
	//Inicializar
	saludoUno = "Hola soy julian";
	saludoDos = " como se encuentran";
	
	//Proceso 
	fConcatenar = Concatenar(saludoUno, saludoDos);
	//Mostrar
	Escribir "Saludo uno es: ","     y saludo dos es : ",saludoDos;
	Escribir fConcatenar;
FinAlgoritmo
