Algoritmo funcionAbs
	
	//Definir variable
	Definir valorUno Como Real;
	Definir fabs Como Real;
	
	//Inicializar
	valorUno = -45.36;
	
	//Proceso 
	fabs = abs(valorUno);
	
	///Mostrar informacion
	Escribir "Valor no absoluto: ",valorUno;
	Escribir "Valor absoluto: ",fabs;
	
FinAlgoritmo
