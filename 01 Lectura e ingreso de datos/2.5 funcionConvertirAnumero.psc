Algoritmo funcionConvertirAnumero
	
	///Definir 
	Definir valorCadena como Cadena;
	Definir numeroFinal Como Real;
	
	///Inicializar
	valorCadena = "456.56";
	
	///Proceso 
	numeroFinal = ConvertirANumero(valorCadena);
	///Mostrar
	Escribir valorCadena, "Este es un string";
	Escribir numeroFinal, "Este es un real";
	
FinAlgoritmo
