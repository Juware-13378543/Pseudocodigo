Algoritmo multiplicacionConstante
	
	///Definir 
	Definir valorUno, valorDos , Mult Como Real;
	
	///Inicializar
	valorUno = 3;
	valorDos = 5;
	
	///Proceso 
	Mult = valorUno * valorDos;
	
	///Mostrar
	Escribir "Los valor multiplicado por: ",valorUno," y ",valorDos," da: ", Mult;
	
FinAlgoritmo
