Algoritmo HallarElAreaDeUnTriangulo
	
	//Definir variables
	Definir Area, Base, Altura Como Real;
	
	//Inicializar variable
	Escribir "Ingrese un valor para La BASE del triangulo";
	Leer Base;
	
	Escribir "Ingrese la Altura del triangulo";
	Leer Altura;
	
	Area = (Base * Altura)/2;
	
	//Mostrar informacion
	Escribir "La Base del triangulo es: ",Base;
	Escribir "La Altura del triangulo es: ",Altura;
	Escribir "";
	Escribir "El area delo triangulo es: ",Area;
FinAlgoritmo
