Algoritmo convertidorCelsiusAFarenheit
	
	///Definir 
	Definir gradosCelsius, gradosFarenheit Como Real;
	
	///Inicializar
	gradosCelsius = 30;
	
	///Proceso 
	gradosFarenheit = (gradosCelsius * 1.8) +32;
	
	///Mostrar
	Escribir "30 celcius son en farenheit: ",gradosFarenheit ;
FinAlgoritmo
