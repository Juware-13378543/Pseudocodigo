Algoritmo funcionTrunc
	
	///Definir variable
	Definir valorUno, valorTrunc Como Real;
	
	///Inicializar
	valorUno = 23.5646161;
	
	///Proceso 
	valorTrunc = trunc(valorUno);
	
	///Mostrar
	Escribir "Valor sin truncado: ",valorUno;
	Escribir "Valor truncado: ", valorTrunc;
FinAlgoritmo
