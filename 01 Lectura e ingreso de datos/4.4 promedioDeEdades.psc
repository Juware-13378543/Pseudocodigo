Algoritmo promedioDeEdades
	
	///Definir 
	Definir valorUno, valorDos, valorTres, valorCuatro, promedio Como Real;
	
	///Inicializar
	valorUno = 4.3;
	valorDos = 3.5;
	valorTres = 2.0;
	valorCuatro = 5.0;
	
	///Proceso
	promedio = (valorUno + valorTres + valorDos + valorCuatro)/4;
	
	///Mostrar
	Escribir "El promedio de notas de juan es: ",promedio;
FinAlgoritmo
