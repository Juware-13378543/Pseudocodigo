Algoritmo edadNacimiento
	
	///Definir 
	Definir valorUno, valorDos, resta, restaAbs Como Real;
	
	///Inicializar
	valorUno = 2007;
	valorDos = 2026;
	
	///Proceso 
	resta = valorUno - valorDos;
	restaAbs = abs(resta);
	
	
	///Mostrar
	Escribir "La edad de julian es: ",restaAbs;
FinAlgoritmo
