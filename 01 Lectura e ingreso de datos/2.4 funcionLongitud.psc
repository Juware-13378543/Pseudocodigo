Algoritmo funcionLongitud
	
	//definir variable
	Definir saludo como Cadena;
	Definir flongitud Como Entero;
	
	//inicializar
	saludo = "Hola como estan";
	
	//Proceso 
	flongitud = Longitud(saludo);
	//Mostrar
	Escribir saludo;
	Escribir flongitud; //Contabiliza cuantos caracteres tien
	FinAlgoritmo
