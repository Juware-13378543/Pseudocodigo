Algoritmo funcionRedon
	
	///Definir variable
	Definir valorUno, valorDos, valorRedon1, valorRedon2 Como Real;
	
	///Inicializacion
	valorUno = 10.5;
	valorDos = 10.4;
	///Proceso 
	valorRedon1 = redon(valorUno);
	valorRedon2 = redon(valorDos);
	
	///Mostrar
	Escribir "Redondeo superior de: 10.5, es ",valorRedon1;
	Escribir "Redondeo inferior de: 10.4, es ",valorRedon2;
	
FinAlgoritmo
