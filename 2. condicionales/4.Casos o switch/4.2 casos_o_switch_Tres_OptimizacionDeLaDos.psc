Algoritmo  casos_o_switch_Tres_OptimizacionDeLaDos
	
	//Definir 
	Definir vocal Como Caracter;
	
	//Variable a evaluar del tipo de dato caracter
	Escribir "Ingrese una vocal";
	Leer vocal;
	
	Segun vocal Hacer
		"A","E","I","O","U","a","e","i","o","u":
			Escribir "La letra ingresa es una vocal"; 
		
		De Otro Modo:
			Escribir "La letra ingresada No es una vocal";
	FinSegun
	
FinAlgoritmo
