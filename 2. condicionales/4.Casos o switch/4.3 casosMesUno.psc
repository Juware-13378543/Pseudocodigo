Algoritmo casosMesUno
	
	//Definir 
	Definir mes como Cadena;
	
	//Variabbel a evaluar Del tioop de dao Cadena
	Escribir "Ingrese un Mes de Ańo";
	Leer mes;
	
	Segun mes Hacer
