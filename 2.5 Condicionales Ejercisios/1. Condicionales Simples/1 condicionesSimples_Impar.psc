Algoritmo condicionesSimples_Impar
	
	//Definir 
	Definir valorIngresado Como Real;
	
	//Inicializar
	Escribir "Ingrese un numero para saber si es impar";
	Leer valorIngresado;
	
	//Condicional simple
	Si ((valorIngresado MOD 2 ) <> 0) Entonces
		Escribir "El numero ingresado si es par";
		
	FinSi
	
FinAlgoritmo
